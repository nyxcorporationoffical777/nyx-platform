# ── NYX Platform — Backend Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# The server reads these via process.env.*

# ── SMTP Email (Nodemailer) ────────────────────────────────────────────────
# If left empty, emails are logged to the console (dev mode).
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=app-password
# SendGrid:      SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASS=SG.xxxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NYX Platform <noreply@nyxplatform.com>

# ── App URL (used in email links) ─────────────────────────────────────────
APP_URL=http://localhost:5173

# ── JWT Secret (change in production!) ────────────────────────────────────
JWT_SECRET=changeme_use_a_long_random_string_in_production

# ── Server Port ───────────────────────────────────────────────────────────
PORT=5000
